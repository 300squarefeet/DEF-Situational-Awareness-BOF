# --- schtasksquery ---
alias schtasksquery {
    local('$bid $host $taskpath $args');
    $bid      = $1;
    $host     = $2;
    $taskpath = $3;
    if ($host is $null)     { $host = ""; }
    if ($taskpath is $null) { $taskpath = "\\"; }
    $args = bof_pack($bid, "zz", $host, $taskpath);
    dani_run($bid, "schtasksquery", $args);
}
beacon_command_register(
    "schtasksquery",
    "Scheduled tasks via COM — T1053.005/T1518",
    "Synopsis: schtasksquery [hostname] [taskpath]\n\n" .
    "Description: Enumerate scheduled tasks using the Task Scheduler COM interface\n" .
    "(ITaskService). Optionally target a remote host and/or specific task folder.\n\n" .
    "Examples:\n" .
    "  schtasksquery\n" .
    "  schtasksquery DC01\n" .
    "  schtasksquery DC01 \\Microsoft\\Windows\n\n" .
    "MITRE ATT&CK: T1053.005 (Scheduled Task/Job: Scheduled Task),\n" .
    "              T1518 (Software Discovery)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: [hostname] [taskpath] (both optional)"
);

# --- reg-query ---
alias reg-query {
    local('$bid $hive $subkey $args');
    $bid    = $1;
    $hive   = $2;
    $subkey = $3;
    if ($hive is $null || $subkey is $null) {
        berror($bid, "Use: reg-query <hive> <subkey>\nExample: reg-query HKLM SOFTWARE\\Microsoft\\Windows\\CurrentVersion");
        return;
    }
    $args = bof_pack($bid, "zz", $hive, $subkey);
    dani_run($bid, "reg-query", $args);
}
beacon_command_register(
    "reg-query",
    "Registry key read — T1012",
    "Synopsis: reg-query <hive> <subkey>\n\n" .
    "Description: Read all values from the specified registry key.\n" .
    "Hive must be one of: HKLM, HKCU, HKCR, HKU, HKCC\n\n" .
    "Examples:\n" .
    "  reg-query HKLM SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\n" .
    "  reg-query HKCU Environment\n\n" .
    "MITRE ATT&CK: T1012 (Query Registry)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: <hive> <subkey> (required)"
);

