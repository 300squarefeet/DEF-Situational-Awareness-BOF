# --- ldapsearch ---
alias ldapsearch {
    local('$bid $basedn $filter $attrs $args');
    $bid    = $1;
    $basedn = $2;
    $filter = $3;
    $attrs  = $4;
    if ($basedn is $null || $filter is $null) {
        berror($bid, "Use: ldapsearch <basedn> <filter> [attrs]\nExample: ldapsearch DC=corp,DC=local (objectClass=user) sAMAccountName,mail");
        return;
    }
    if ($attrs is $null) { $attrs = ""; }
    $args = bof_pack($bid, "zzz", $basedn, $filter, $attrs);
    dani_run($bid, "ldapsearch", $args);
}
beacon_command_register(
    "ldapsearch",
    "LDAP query — T1087.002/T1018",
    "Synopsis: ldapsearch <basedn> <filter> [attrs]\n\n" .
    "Description: Execute an LDAP search against the domain controller using\n" .
    "paged results. Returns matching objects with requested attributes.\n\n" .
    "Examples:\n" .
    "  ldapsearch DC=corp,DC=local (objectClass=computer) name,dNSHostName\n" .
    "  ldapsearch DC=corp,DC=local (objectClass=user) sAMAccountName,memberOf\n\n" .
    "MITRE ATT&CK: T1087.002 (Account Discovery: Domain Account),\n" .
    "              T1018 (Remote System Discovery)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: <basedn> <filter> [attrs] (attrs optional)"
);

