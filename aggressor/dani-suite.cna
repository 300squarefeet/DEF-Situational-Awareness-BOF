# --- findmodule ---
alias findmodule {
    local('$bid $pid $modname $args');
    $bid     = $1;
    $pid     = $2;
    $modname = $3;
    if ($pid is $null || $modname is $null) {
        berror($bid, "Use: findmodule <pid> <modulename>\nExample: findmodule 4424 amsi.dll");
        return;
    }
    $args = bof_pack($bid, "zz", $pid, $modname);
    dani_run($bid, "findmodule", $args);
}
beacon_command_register(
    "findmodule",
    "Find module in remote process — T1057",
    "Synopsis: findmodule <pid> <modulename>\n\n" .
    "Description: Check whether a specific DLL/module is loaded in a\n" .
    "target process by PID. Useful for detecting security product DLLs\n" .
    "injected into running processes.\n\n" .
    "Examples:\n" .
    "  findmodule 4424 amsi.dll\n" .
    "  findmodule 1234 MpOav.dll\n\n" .
    "MITRE ATT&CK: T1057 (Process Discovery)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: <pid> <modulename> (required)"
