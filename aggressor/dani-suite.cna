# ============================================================
# ============================================================
# META-COMMAND: dani-help
# ============================================================
# ============================================================

alias dani-help {
    local('$bid');
    $bid = $1;
    blog($bid, "=================================================================");
    blog($bid, "  DEF-Situational-Awareness-BOF");
    blog($bid, "  157 BOFs across 6 phases  |  Use 'help <cmd>' for full syntax");
    blog($bid, "=================================================================");
    blog($bid, "");
    blog($bid, "PHASE 1 — Canary (3 BOFs, no args)");
    blog($bid, "  uptime         T1082     Uptime via KUSER_SHARED_DATA");
    blog($bid, "  hostname       T1082     NetBIOS/DNS/FQDN via DFR");
    blog($bid, "  whoami         T1033/34  Token info via indirect syscall");
    blog($bid, "");
