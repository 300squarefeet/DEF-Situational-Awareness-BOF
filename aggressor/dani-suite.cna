#
# dani-suite.cna — Single Cobalt Strike aggressor script
# Registers all 69 BOFs in DEF-Situational-Awareness-BOF as native beacon commands.
#
# Usage: Load via Cobalt Strike Script Manager (CS 4.x+)
#        File → Script Manager → Load → dani-suite.cna
#
# Layout assumption:
#   aggressor/dani-suite.cna   (this file)
#   dist/<bof>.x64.o           (built artifacts)
#
# script_resource("../dist/X.x64.o") resolves relative to this .cna's directory.
#
# Phase 1 — Canary              (3 BOFs)
# Phase 2 — Situational Aware   (26 BOFs)
# Phase 2 — SA gap-fill batch 1 (12 BOFs)
# Phase 3 — Remote Ops          (18 BOFs)
# Phase 4 — OperatorsKit        (12 BOFs)
# Phase 4 — C2-Collection       (8 BOFs)
# Phase 5 — Persistence         (2 BOFs)
# Phase 6 — Loader              (1 BOF)
# Phase 2 gap-fill — SA (21 BOFs)
# Phase 3 gap-fill — Remote-Ops (26 BOFs)
# Phase 4 gap-fill — OperatorsKit (23 BOFs)
# Phase 5 gap-fill — C2-Collection (5 BOFs)
# Total: 158 registered commands (157 BOFs + dani-help meta)

# ============================================================
# LOAD-TIME BANNER
# ============================================================
println("============================================================");
println("  DEF-Situational-Awareness-BOF");
println("  157 BOFs across 6 phases loaded");
println("  Type 'dani-help' in a beacon for the full command list.");
println("============================================================");

# ============================================================
# HELPER — shared path-check + execute
# ============================================================
sub dani_run {
    # $1 = bid, $2 = bof name (no extension), $3 = packed args (or "")
    local('$bid $name $args $path $handle $data');
    $bid  = $1;
    $name = $2;
    $args = $3;
    $path = script_resource("../dist/" . $name . ".x64.o");
    if (!-exists $path) {
        berror($bid, "[dani-suite] " . $name . ".x64.o not found at: " . $path);
        berror($bid, "Run 'bash scripts/build_all.sh' in the repo root to build all BOFs.");
        return;
    }
    # Read BOF as binary blob (Cobalt Strike's beacon_inline_execute requires
    # raw COFF data, NOT a file path). openf/readb/closef is the standard
    # Aggressor idiom for binary file I/O.
    $handle = openf($path);
    $data   = readb($handle, -1);
    closef($handle);
    if ($data is $null || strlen($data) == 0) {
        berror($bid, "[dani-suite] failed to read " . $name . ".x64.o (empty/missing)");
        return;
    }
    beacon_inline_execute($bid, $data, "go", $args);
}

