# --- probe ---
alias probe {
    local('$bid $target $ports $args');
    $bid    = $1;
    $target = $2;
    if ($target is $null || size(@_) < 3) {
        berror($bid, "Use: probe <host-or-ip-or-cidr> <ports>\n" .
                     "Examples:\n" .
                     "  probe dc01.corp.local 445\n" .
                     "  probe 192.168.1.6 443 445 80\n" .
                     "  probe 192.168.1.6/24 443,445,80");
        return;
    }
    $ports = join(" ", sublist(@_, 2));
    $args  = bof_pack($bid, "zzz", $target, $ports, "");
    dani_run($bid, "probe", $args);
}
beacon_command_register(
    "probe",
    "TCP port probe — hostname/IPv4/CIDR + multi-port — T1046",
    "Synopsis: probe <host-or-ip-or-cidr> <ports> [timeout-ms]\n\n" .
    "Description: Probe TCP ports on a hostname (DNS-resolved), single IPv4,\n" .
    "or CIDR range. Like portscan but adds hostname resolution via getaddrinfo.\n\n" .
    "Target formats:\n" .
    "  dc01.corp.local     hostname (DNS resolved)\n" .
